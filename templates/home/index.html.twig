<section class="hero">

  <video class="hero-photo" autoplay muted loop playsinline>
    <source src="{{ asset('header.mp4') }}" type="video/mp4">
  </video>

  <div class="hero-content">

    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      Depuis 1956
    </div>

    <h1>Blanchisserie</h1>
    <h2>industrielle et hospitalière</h2>

    <div class="hero-separator">
      <span class="sep-green"></span>
      <span class="sep-blue"></span>
    </div>

    <div class="hero-dot">
      <span class="dot"></span>
      au cœur de la Région Wallonne
    </div>

    <p>Depuis 1956, Servitex accompagne les professionnels de la santé et de l'industrie avec un service de blanchisserie <strong>fiable, durable et de proximité.</strong></p>

    <a href="#" class="hero-btn">
      Découvrir nos services
      <span class="hero-btn-icon">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M1 5h8M5 1l4 4-4 4" stroke="#0E182D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

  </div>

  <svg class="hero-courbe" viewBox="0 0 680 340" preserveAspectRatio="none">
    <defs>
      <linearGradient id="zoneGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#F5F8FB" stop-opacity="0.5"/>
        <stop offset="18%"  stop-color="#F5F8FB" stop-opacity="0.96"/>
        <stop offset="100%" stop-color="#F5F8FB" stop-opacity="0.97"/>
      </linearGradient>
      <linearGradient id="traitGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#0D47A1" stop-opacity="0"/>
        <stop offset="25%"  stop-color="#0D47A1" stop-opacity="0.8"/>
        <stop offset="50%"  stop-color="#0D47A1" stop-opacity="1"/>
        <stop offset="75%"  stop-color="#0D47A1" stop-opacity="0.8"/>
        <stop offset="100%" stop-color="#0D47A1" stop-opacity="0"/>
      </linearGradient>
      <linearGradient id="eventailHaut" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#0D47A1" stop-opacity="0.22"/>
        <stop offset="100%" stop-color="#0D47A1" stop-opacity="0"/>
      </linearGradient>
      <linearGradient id="reflet" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%"   stop-color="#ffffff" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
      </linearGradient>
    </defs>

    <!-- Zone claire -->
    <path d="M0,0 L172,1 C234,65 269,118 279,282 L279,340 L0,340 Z"
      fill="url(#zoneGrad)"/>

    <!-- Reflet lumineux -->
    <path d="M0,0 L172,1 C234,65 269,118 279,282 L279,340 L0,340 Z"
      fill="url(#reflet)"/>

    <!-- Accent blanc gauche : creux vers le bas, rejoint le vert en x=340 -->
    <path d="M0,305 C80,330 200,342 340,340 L0,340 Z"
      fill="#F5F8FB"/>

    <!-- Accent vert droite : creux vers le bas, rejoint le blanc en x=340 -->
    <path d="M340,340 C460,348 600,332 680,305 L680,340 Z"
      fill="#A8D63A"/>

    <!-- Éventail bleu -->
    <path d="M157,1 C219,65 264,118 279,190 C264,118 249,65 187,1 Z"
      fill="url(#eventailHaut)"/>

    <!-- Trait bleu épais -->
    <path d="M172,1 C234,65 269,118 279,282 L279,340"
      fill="none" stroke="url(#traitGrad)" stroke-width="7" stroke-linecap="round"/>

    <!-- Reflet blanc sur le trait -->
    <path d="M172,1 C234,65 269,118 279,282 L279,340"
      fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2" stroke-linecap="round"/>

    <!-- Trait fin -->
    <path d="M172,1 C234,65 269,118 279,282 L279,340"
      fill="none" stroke="#0D47A1" stroke-width="1.5" stroke-opacity="0.2" stroke-linecap="round"/>

  </svg>

</section>

