{# hero.html.twig #}
<section class="hero" aria-label="Blanchisserie industrielle et hospitalière">

  {# === BACKGROUND LAYER === #}
  <div class="hero__bg">
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-noise"></div>
    <div class="hero__bg-grid"></div>
  </div>

  {# === ORGANIC CURVES SVG === #}
  <div class="hero__curves">
    <svg class="hero__curve hero__curve--1" viewBox="0 0 800 600" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 C200,80 400,0 600,120 C750,200 800,100 800,0 Z" fill="rgba(255,255,255,0.04)"/>
    </svg>
    <svg class="hero__curve hero__curve--2" viewBox="0 0 1000 400" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,400 C150,300 300,380 500,320 C700,260 850,320 1000,280 L1000,400 Z" fill="rgba(178,212,0,0.12)"/>
    </svg>
    <svg class="hero__curve hero__curve--3" viewBox="0 0 600 800" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M600,0 C520,150 580,300 500,450 C420,600 480,700 600,800 Z" fill="rgba(30,90,160,0.15)"/>
    </svg>
  </div>

  {# === FLOATING PARTICLES === #}
  <div class="hero__particles" aria-hidden="true">
    {% for i in 1..12 %}
      <span class="hero__particle hero__particle--{{ i }}"></span>
    {% endfor %}
  </div>

  {# === MAIN CONTENT WRAPPER === #}
  <div class="hero__container">

    {# LEFT — TEXT CONTENT #}
    <div class="hero__content">

      <div class="hero__badge">
        <span class="hero__badge-dot"></span>
        <span class="hero__badge-text">au cœur de la Région Wallonne</span>
      </div>

      <h1 class="hero__title">
        <span class="hero__title-line hero__title-line--dark">Blanchisserie</span>
        <span class="hero__title-line hero__title-line--accent">industrielle et</span>
        <span class="hero__title-line hero__title-line--accent">hospitalière</span>
      </h1>

      <p class="hero__desc">
        Depuis 1956, Servitex accompagne les professionnels de la santé et de l'industrie
        avec un service de blanchisserie fiable, durable et de proximité.
      </p>

      <div class="hero__actions">
        <a href="#services" class="hero__btn hero__btn--primary">
          <span class="hero__btn-text">Découvrir nos services</span>
          <span class="hero__btn-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
          <span class="hero__btn-ripple"></span>
        </a>
        <a href="#contact" class="hero__btn hero__btn--ghost">
          <span>Nous contacter</span>
        </a>
      </div>

      {# STATS ROW #}
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-num" data-count="1956">1956</span>
          <span class="hero__stat-label">Fondée en</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num" data-count="68">68</span>
          <span class="hero__stat-label">Années d'expertise</span>
        </div>
        <div class="hero__stat-sep" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-num">ISO</span>
          <span class="hero__stat-label">Certifiée 9001</span>
        </div>
      </div>

    </div>

    {# RIGHT — IMAGE PANE #}
    <div class="hero__visual">

      {# DECORATIVE RING #}
      <div class="hero__ring hero__ring--outer" aria-hidden="true">
        <svg viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg">
          <circle cx="250" cy="250" r="240" fill="none" stroke="rgba(178,212,0,0.3)" stroke-width="1" stroke-dasharray="8 14"/>
        </svg>
      </div>
      <div class="hero__ring hero__ring--inner" aria-hidden="true">
        <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="190" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="4 10"/>
        </svg>
      </div>

      {# IMAGE FRAME #}
      <div class="hero__image-frame">
        <div class="hero__image-mask">
          <img
            src="{{ asset('images/hero-laundry.jpg') }}"
            alt="Technicienne Servitex au travail dans la blanchisserie"
            class="hero__image"
            loading="eager"
            width="680"
            height="580"
          />
          <div class="hero__image-overlay"></div>
        </div>

        {# FLOATING CARD — certification #}
        <div class="hero__card hero__card--cert">
          <div class="hero__card-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <polyline points="9 12 11 14 15 10"/>
            </svg>
          </div>
          <div class="hero__card-body">
            <strong class="hero__card-title">Qualité garantie</strong>
            <span class="hero__card-sub">Norme EN 14065</span>
          </div>
        </div>

        {# FLOATING CARD — livraisons #}
        <div class="hero__card hero__card--delivery">
          <div class="hero__card-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h4l3 5v3h-7V8z"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div class="hero__card-body">
            <strong class="hero__card-title">Livraison rapide</strong>
            <span class="hero__card-sub">Région Wallonne</span>
          </div>
          <div class="hero__card-pulse" aria-hidden="true"></div>
        </div>

        {# LIME ACCENT SHAPE #}
        <div class="hero__lime-blob" aria-hidden="true">
          <svg viewBox="0 0 200 120" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,120 C40,60 100,80 160,30 C180,15 200,5 200,0 L200,120 Z" fill="#b2d400"/>
          </svg>
        </div>
      </div>

    </div>
  </div>

  {# BOTTOM WAVE TRANSITION #}
  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,90 C240,20 480,80 720,40 C960,0 1200,60 1440,30 L1440,90 Z" fill="#ffffff"/>
      <path d="M0,90 C360,50 720,70 1080,35 C1260,18 1380,55 1440,50 L1440,90 Z" fill="rgba(255,255,255,0.4)"/>
    </svg>
  </div>

  {# SERVICES STRIP — bottom icons row #}
  <div class="hero__services-strip">
    <div class="hero__services-inner">

      {% set services = [
        { icon: 'washing',   label: 'Entretien du linge',       sub: 'et des vêtements' },
        { icon: 'hanger',    label: 'Location de linge',        sub: 'et de vêtements' },
        { icon: 'truck',     label: 'Logistique',               sub: 'et transport' },
        { icon: 'tracking',  label: 'Gestion et',              sub: 'traçabilité' },
        { icon: 'advice',    label: 'Conseils et',              sub: 'formations' },
        { icon: 'fullserv',  label: 'Système',                 sub: 'full-service' },
      ] %}

      {% for service in services %}
        <div class="hero__service-item">
          <div class="hero__service-icon-wrap">

            {% if service.icon == 'washing' %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="6" y="8" width="36" height="32" rx="3" stroke="currentColor" stroke-width="2"/>
                <circle cx="24" cy="27" r="8" stroke="currentColor" stroke-width="2"/>
                <circle cx="24" cy="27" r="4" stroke="currentColor" stroke-width="1.5" stroke-dasharray="3 3"/>
                <rect x="10" y="12" width="4" height="4" rx="1" fill="currentColor" opacity=".4"/>
                <rect x="16" y="12" width="4" height="4" rx="1" fill="currentColor" opacity=".4"/>
                <line x1="6" y1="20" x2="42" y2="20" stroke="currentColor" stroke-width="1.5"/>
              </svg>

            {% elseif service.icon == 'hanger' %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 14 C24 14 24 10 28 10 C32 10 32 14 28 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M24 14 L6 34 H42 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <line x1="6" y1="38" x2="42" y2="38" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>

            {% elseif service.icon == 'truck' %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="14" width="26" height="20" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M30 20 H40 L44 28 V34 H30 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <circle cx="12" cy="36" r="4" stroke="currentColor" stroke-width="2"/>
                <circle cx="36" cy="36" r="4" stroke="currentColor" stroke-width="2"/>
                <line x1="16" y1="36" x2="32" y2="36" stroke="currentColor" stroke-width="2"/>
              </svg>

            {% elseif service.icon == 'tracking' %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="24" cy="24" r="4" fill="currentColor"/>
                <path d="M14 24 C14 18.5 18.5 14 24 14 C29.5 14 34 18.5 34 24 C34 29.5 29.5 34 24 34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M8 24 C8 14.6 15.2 7 24 7 C32.8 7 40 14.6 40 24 C40 33.4 33 40 24 40" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".5"/>
              </svg>

            {% elseif service.icon == 'advice' %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M24 8 C14.6 8 7 14.6 7 24 C7 28.4 8.8 32.4 11.8 35.2 L10 40 L15.8 38.4 C18.3 39.7 21.1 40.4 24 40.4 C33.4 40.4 41 33.8 41 24 C41 14.6 33.4 8 24 8 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <line x1="18" y1="22" x2="30" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="18" y1="28" x2="26" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>

            {% else %}
              <svg class="hero__service-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polyline points="6,6 18,6 18,18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="42,42 30,42 30,30" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="42,6 30,6 30,18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polyline points="6,42 18,42 18,30" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            {% endif %}

          </div>
          <div class="hero__service-label">
            <strong>{{ service.label }}</strong>
            <span>{{ service.sub }}</span>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>

</section>



</header>

<main>


    
</main>
    
</div>
{% endblock %}
